# ── mc-auth configuration ────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.

PORT=7900
DB_PATH=/data/mc-auth.sqlite
PUBLIC_BASE_URL=https://minecraft.mncoleman.com

# Shared HS256 secret. The EaglercraftXServer JWT plugin MUST use the SAME value.
# Generate: openssl rand -hex 48
MC_JWT_SECRET=

# Session cookie
COOKIE_NAME=mc_session
SESSION_TTL_DAYS=7
# Set true ONLY for local http dev (drops the Secure flag). Leave unset in prod.
# DEV_INSECURE_COOKIE=true

# JWT audience the plugin checks (keep in sync with the plugin config)
JWT_AUDIENCE=minecraft.mncoleman.com

# ── Telegram login (reuse your bot, same pattern as artifacts) ────────────────
# Create/Use a bot via @BotFather; set its domain to minecraft.mncoleman.com
# (BotFather → /setdomain). The widget needs the bot's @username (no @).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ── Telegram presence notifications (owner-only, server-side) ─────────────────
# A "me only" feature: DMs the owner when someone joins the server, with a
# bot-command menu (/status, /on, /off). Uses long-polling (getUpdates) — no
# webhook/public route needed. SEPARATE from the login bot above so the two
# never collide. Leave the token blank to disable the whole feature.
#   - TELEGRAM_NOTIFY_BOT_TOKEN: BotFather token for the notification bot.
#   - TELEGRAM_NOTIFY_CHAT_ID:   the ONLY chat the bot answers (owner's user id).
#   - TELEGRAM_NOTIFY_IGNORE:    in-game names to never ping about (default the
#                                owner himself), comma-separated, case-insensitive.
TELEGRAM_NOTIFY_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=
# TELEGRAM_NOTIFY_IGNORE=Matthew

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console → Credentials → OAuth client (Web application).
# Authorized redirect URI: https://minecraft.mncoleman.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Transactional email (Resend) ──────────────────────────────────────────────
# Used for email confirmation, password reset, and invite-by-email.
# Get the API key at https://resend.com (Dashboard → API Keys). The FROM address
# must be on a domain verified in Resend (DKIM). If RESEND_API_KEY is empty the
# mailer no-ops (logs the email it would have sent) so the app still runs.
RESEND_API_KEY=
RESEND_FROM=MNColeman Minecraft <mail@mncoleman.com>

# ── Feedback → GitHub issues ──────────────────────────────────────────────────
# The Feedback tab records each submission, DMs the owner over Telegram (reuses
# TELEGRAM_NOTIFY_BOT_TOKEN / TELEGRAM_NOTIFY_CHAT_ID above), and files a GitHub
# issue in the repo below. If GITHUB_ISSUES_TOKEN is empty the form still works
# (records + Telegram); it just skips creating the issue.
#   - GITHUB_ISSUES_TOKEN: a fine-grained PAT scoped to the repo, with the
#       "Issues: Read and write" permission (github.com/settings/tokens).
#   - GITHUB_REPO: owner/name to open issues in. Defaults to mncoleman/minecraft.
GITHUB_ISSUES_TOKEN=
GITHUB_REPO=mncoleman/minecraft

# ── Admins (these identities get the /admin panel + is_admin) ─────────────────
# Comma-separated. Match however they log in.
ADMIN_EMAILS=mncoleman003@gmail.com
ADMIN_TELEGRAM_IDS=

# ── World limits (optional; sensible defaults if unset) ───────────────────────
# WORLD_CAP: total worlds across the whole server (protects disk). Default 8.
# PER_USER_WORLD_CAP: how many worlds a non-admin may own. Admins are bound only
# by WORLD_CAP. Default 3.
# WORLD_CAP=8
# PER_USER_WORLD_CAP=3

# ── Bootstrap allowlist (seeded into the DB on first start if empty) ──────────
# Format: kind:value[:username], comma-separated.
#   kind = email | telegram | google | username
#   username (optional) = the in-game name to assign that person
# Example:
# ALLOWLIST=email:mncoleman003@gmail.com:Matthew, telegram:2008660091:Matthew, email:friend@example.com:Steve
ALLOWLIST=
