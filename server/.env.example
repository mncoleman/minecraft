# Game-server container secrets. Copy to .env (never commit .env).
# All three are SHARED with the mc-auth service and must match byte-for-byte.

# HS256 secret. The EaglerJwtAuth plugin reads this from the environment to
# validate session cookies. MUST equal mc-auth's MC_JWT_SECRET.
# Generate once: openssl rand -hex 48
MC_JWT_SECRET=

# RCON password. RCON is enabled on the in-container port 25575 (never published);
# the mc-auth service connects to it for the command center, world sharing, hop,
# etc. MUST equal mc-auth's RCON_PASSWORD.
# Generate once: openssl rand -hex 24
RCON_PASSWORD=

# Presence token. The plugin exposes an in-container "who is online" endpoint
# guarded by this bearer token; mc-auth polls it. MUST equal mc-auth's
# MC_PRESENCE_TOKEN.
# Generate once: openssl rand -hex 24
MC_PRESENCE_TOKEN=
